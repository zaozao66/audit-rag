{
  "development": {
    "embedding_model": {
      "provider": "openai",
      "model_name": "text-embedding-v4",
      "api_key": "YOUR_DEVELOPMENT_API_KEY_HERE",
      "endpoint": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "dimension": 1024,
      "ssl_verify": true
    },
    "rerank_model": {
      "provider": "aliyun",
      "model_name": "qwen3-rerank",
      "api_key": "YOUR_DEVELOPMENT_API_KEY_HERE",
      "endpoint": "https://dashscope.aliyuncs.com/compatible-api/v1",
      "dimension": 1024,
      "ssl_verify": true
    },
    "llm_model": {
      "provider": "deepseek",
      "model_name": "deepseek-chat",
      "api_key": "YOUR_DEEPSEEK_API_KEY_HERE",
      "endpoint": "https://api.deepseek.com/v1",
      "temperature": 0.7,
      "max_tokens": 2000,
      "ssl_verify": true
    },
    "asr_proxy": {
      "endpoint": "https://your-asr-endpoint.com/v1",
      "path": "/audio/transcriptions",
      "api_key": "YOUR_ASR_API_KEY_HERE",
      "model_name": "qwen3-asr",
      "request_timeout": 60,
      "ssl_verify": true
    },
    "department_portrait_ai": {
      "endpoint": "https://your-llm-endpoint.com/v1",
      "api_key": "YOUR_DEPARTMENT_AI_API_KEY_HERE",
      "model_name": "GLM-4.7-W8A8",
      "temperature": 0.3,
      "max_tokens": 1200,
      "request_timeout": 60,
      "ssl_verify": true
    },
    "chunking": {
      "chunk_size": 512,
      "overlap": 50,
      "chunker_type": "smart"
    },
    "search": {
      "top_k": 5,
      "similarity_threshold": 0.5
    },
    "conversation": {
      "max_messages": 24,
      "ttl_minutes": 120
    },
    "audio": {
      "script": {
        "max_chars": 1200
      },
      "tts": {
        "provider": "qwen",
        "model": "qwen3-tts-flash-2025-11-27",
        "default_voice": "Cherry",
        "default_format": "mp3",
        "default_sample_rate": 24000,
        "request_timeout": 20,
        "ssl_verify": true,
        "output_dir": "./data/audio_cache",
        "public_base_path": "/v1/audio/files",
        "cache_ttl_hours": 48,
        "cache_max_disk_mb": 2048,
        "providers": {
          "qwen": {
            "endpoint": "https://dashscope.aliyuncs.com/compatible-mode/v1",
            "api_key": "YOUR_DEVELOPMENT_API_KEY_HERE",
            "model": "qwen3-tts-flash-2025-11-27"
          },
          "cosyvoice": {
            "endpoint": "http://cosyvoice-internal:9880",
            "path": "/tts",
            "default_voice": "default"
          },
          "melotts": {
            "endpoint": "http://melotts-internal:5000",
            "path": "/tts",
            "default_voice": "default"
          }
        }
      }
    },
    "file_storage": {
      "storageType": "local",
      "localRootDir": "./appData",
      "metadataPath": "./appData/file_storage_metadata.json",
      "uploadTempDir": "./appData/upload_sessions",
      "uploadSessionTtlHours": 24,
      "chunkUploadSizeBytes": 8388608
    },
    "default_scope": "audit",
    "scope_required": false,
    "knowledge_scopes": {
      "audit": {
        "vector_store_path": "./data/vector_store_text_embedding",
        "features": {
          "intent_router": true
        },
        "intent_router": {
          "enabled": true
        },
        "retrieval_defaults": {
          "retrieval_mode": "hybrid",
          "graph_top_k": 12,
          "graph_hops": 2,
          "hybrid_alpha": 0.65
        }
      },
      "discipline": {
        "vector_store_path": "./data/discipline/vector_store_text_embedding",
        "features": {
          "intent_router": false
        },
        "intent_router": {
          "enabled": false,
          "fixed_top_k": 8
        },
        "retrieval_defaults": {
          "retrieval_mode": "vector",
          "graph_top_k": 8,
          "graph_hops": 1,
          "hybrid_alpha": 1.0
        }
      }
    }
  },
